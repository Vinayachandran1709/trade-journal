{
  "manifest_version": 3,
  "name": "IndiaCircle - AI Trading Copilot",
  "description": "Auto-journal every trade across 10+ Indian brokers. AI-powered analysis, behavioral insights & smart calculators.",
  "version": "1.2.0",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://indiacircle.in/*",
    "https://www.indiacircle.in/*",
    "https://kite.zerodha.com/*",
    "https://groww.in/*",
    "https://web.groww.in/*",
    "https://www.moneycontrol.com/*",
    "https://moneycontrol.com/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IndiaCircle"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kite.zerodha.com/*",
        "https://groww.in/*",
        "https://web.groww.in/*"
      ],
      "js": ["content-scripts/broker-detector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kite.zerodha.com/*",
        "https://groww.in/stocks/*",
        "https://web.groww.in/stocks/*"
      ],
      "js": ["content-scripts/checklist-overlay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content-scripts/ticker-highlighter.js"],
      "run_at": "document_idle"
    }
  ]
}
